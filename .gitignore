*.pem
*.key

# Editor / sistema operacional
.vscode/
.idea/
.DS_Store
Thumbs.db

# Dados gerados pelo pipeline (bronze/silver/gold são derivados, não fonte)
# Mantenha as pastas no repo, não o conteúdo transiente. Descomente para ignorar
# a saída das execuções locais:
# datalake/bronze/*.json
# datalake/silver/*.json
# datalake/silver/*.csv
# datalake/gold/*.json
